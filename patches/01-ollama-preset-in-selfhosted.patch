 }
 
+type ProbeState =
+  | { status: "idle" }
+  | { status: "probing" }
+  | { status: "up"; models: string[] }
+  | { status: "down"; reason: string };
+
+const OLLAMA_PRESET_URL = "http://localhost:11434/v1";
+
 export default function SelfHostedPanel({ service, url, onUrlChange }: SelfHostedPanelProps) {
   const { t } = useTranslation();
+  const [probe, setProbe] = useState<ProbeState>({ status: "idle" });
 
   const placeholderUrl =
     service === "transcription" ? "http://192.168.1.126:8178" : "http://192.168.1.126:8080";
 
+  const trimmedUrl = useMemo(() => url.trim(), [url]);
