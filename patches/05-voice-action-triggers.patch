+  // talktype patch: voice-action trigger detection.
+  _detectVoiceAction(text) {
+    if (typeof text !== "string" || !text) return { text, actionKey: null };
+    // Each entry: [regex matching the trigger at end of text, key to fire].
+    // Regex captures trailing punctuation + whitespace so the strip is clean.
+    // Persian + English. `u` flag enables full Unicode matching.
+    // Shared tail fragment — colloquial filler that may follow a Persian trigger.
+    // e.g. "بفرست بره", "بفرست دیگه", "انجام بده همین الان".
+    const FA_TAIL = String.raw`(?:\s+(?:بره|برو|بعد|دیگه|همین\s*الان|همین|این|اون|الان))*`;
+
+    const RULES = [
+      // ── Enter / Return ─────────────────────────────────────────────
+      // English
+      [/(?:^|[\s,.!?;:])(?:send\s+(?:it|this|message)|press\s+enter|hit\s+enter|submit(?:\s+it)?|post\s+(?:it|this)|go\s+ahead|do\s+it|send\s+go)[\s.!?]*$/iu, "return"],
+      // Persian (Farsi) — colloquial + formal forms.
+      // Handles leading-only-trigger (no separator required), optional colloquial tail,
+      // and the common Whisper typo "به فرستش" (space inserted by the ASR).
+      [new RegExp(
+        `(?:^|[\\s،.!؟؛:])(?:بفرستش|بفرستیدش|ارسالش\\s*کن|ارسال\\s*کن|بفرست|اوکی\\s*کن|تایید\\s*کن|انجام\\s*بده|اجرا(?:ش)?\\s*کن|به\\s+فرستش|ارسال)${FA_TAIL}[\\s.،!؟]*$`,
+        "iu"
+      ), "return"],
+
+      // ── Tab ────────────────────────────────────────────────────────
+      [/(?:^|[\s,.!?;:])(?:press\s+tab|hit\s+tab|next\s+field|tab\s+over)[\s.!?]*$/iu, "tab"],
+      [new RegExp(
+        `(?:^|[\\s،.!؟؛:])(?:تب\\s*بزن|فیلد\\s*بعدی|برو\\s*بعدی)${FA_TAIL}[\\s.،!؟]*$`,
+        "iu"
+      ), "tab"],
+
+      // ── Escape / Cancel ────────────────────────────────────────────
+      [/(?:^|[\s,.!?;:])(?:press\s+escape|hit\s+escape|cancel\s+(?:this|it)|close\s+(?:this|it|dialog))[\s.!?]*$/iu, "escape"],
+      [new RegExp(
+        `(?:^|[\\s،.!؟؛:])(?:کنسل\\s*کن|ببندش|لغوش\\s*کن|بی\\s*خیال)${FA_TAIL}[\\s.،!؟]*$`,
+        "iu"
+      ), "escape"],
+    ];
+    for (const [re, key] of RULES) {
+      if (re.test(text)) {
+        const stripped = text.replace(re, "").trimEnd();
+        return { text: stripped, actionKey: key };
+      }
+    }
+    return { text, actionKey: null };
+  }
