+    // talktype patch: simulate a single key press (for post-paste voice actions
+    // like "send it" → Enter). macOS uses osascript; Windows uses PowerShell
+    // SendKeys. Safelist keeps the surface small; grow deliberately.
+    ipcMain.handle("simulate-key-press", async (event, keyName) => {
+      try {
+        const SAFE_KEYS_MAC = {
+          return: 36, // macOS key codes for System Events "key code N"
+          enter: 36,
+          tab: 48,
+          escape: 53,
+        };
+        const SAFE_KEYS_WIN = {
+          return: "{ENTER}",
+          enter: "{ENTER}",
+          tab: "{TAB}",
+          escape: "{ESC}",
+        };
+        const normalized = String(keyName || "").toLowerCase();
+        const { spawn } = require("child_process");
+        if (process.platform === "darwin") {
+          const code = SAFE_KEYS_MAC[normalized];
+          if (!code) return { success: false, error: `key '${keyName}' not in safelist` };
+          await new Promise((resolve, reject) => {
+            const proc = spawn("osascript", [
+              "-e",
+              `tell application "System Events" to key code ${code}`,
+            ]);
+            proc.on("error", reject);
+            proc.on("close", (exitCode) =>
+              exitCode === 0 ? resolve() : reject(new Error(`osascript exit ${exitCode}`))
+            );
+          });
+        } else if (process.platform === "win32") {
+          const keystroke = SAFE_KEYS_WIN[normalized];
+          if (!keystroke) return { success: false, error: `key '${keyName}' not in safelist` };
+          await new Promise((resolve, reject) => {
+            const proc = spawn("powershell", [
+              "-NoProfile",
+              "-Command",
+              `[void][System.Reflection.Assembly]::LoadWithPartialName('System.Windows.Forms'); [System.Windows.Forms.SendKeys]::SendWait('${keystroke}')`,
+            ]);
+            proc.on("error", reject);
+            proc.on("close", (code) =>
+              code === 0 ? resolve() : reject(new Error(`powershell exit ${code}`))
+            );
+          });
+        } else {
+          return { success: false, error: `simulate-key-press: ${process.platform} not implemented yet` };
+        }
+        return { success: true };
+      } catch (err) {
+        return { success: false, error: err.message };
+      }
+    });
